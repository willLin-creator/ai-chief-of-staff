# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and will never be committed.

# --- Google (used by scripts/gdocs.py and scripts/gsheets.py) ---
# Path to your Google OAuth *client* credentials JSON (download from Google Cloud Console).
GOOGLE_OAUTH_CLIENT_FILE=~/.config/ai-cos/gcp-oauth.keys.json
# Path where the stored OAuth *token* will be cached after first authorization.
GOOGLE_TOKEN_FILE=~/.config/ai-cos/google-token.json

# --- Optional integrations (only needed if you wire up the matching script) ---
# MIXPANEL_PROJECT_ID=
# MIXPANEL_SERVICE_USERNAME=
# MIXPANEL_SERVICE_SECRET=
